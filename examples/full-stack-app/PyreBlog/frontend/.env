# API base URL. Empty = same-origin (served from the PYRE canister).
# For local dev against a replica, override in .env.local, e.g.:
#   VITE_API_BASE=http://localhost:4943
VITE_API_BASE=

# Public Google OAuth client ID for Google Identity Services (Phase B/C).
# Leave empty to disable Google sign-in and fall back to the "sign in to
# comment" placeholder. This is a PUBLIC client id, not a secret.
VITE_GOOGLE_CLIENT_ID=
