# In dev, point at a local replica by default. Override in .env.local.
# Empty keeps it same-origin so `vite preview` of a canister-served build works.
VITE_API_BASE=
VITE_GOOGLE_CLIENT_ID=

# Dev only: serve the app from an in-memory mock canister (no backend needed).
# Run as: VITE_USE_MOCK=1 npm run dev   (or uncomment below)
# VITE_USE_MOCK=1
