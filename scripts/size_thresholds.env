# WASM size thresholds for scripts/size_gate.sh — sourced as shell defaults,
# override any value via the environment (same convention as budget_gate.sh).
#
# Baselines measured 2026-07-02 from local Kybra 0.7.1 builds:
#   canister       raw .wasm     .wasm.gz (shipped)
#   rest_api       27,305,421    14,189,988
#   food_tracker   27,313,681    14,187,387
#   outbound       27,307,598    14,184,693
#   phase1_spike   26,824,041    13,927,907
#
# Thresholds are ~10% above baseline (tight on purpose: "adding a fat crate
# fails CI on size/idle" — bump these deliberately, with a note in the PR,
# never to make a red build green).

MAX_RAW_rest_api="${MAX_RAW_rest_api:-30100000}"
MAX_GZ_rest_api="${MAX_GZ_rest_api:-15700000}"

MAX_RAW_food_tracker="${MAX_RAW_food_tracker:-30100000}"
MAX_GZ_food_tracker="${MAX_GZ_food_tracker:-15700000}"

MAX_RAW_outbound="${MAX_RAW_outbound:-30100000}"
MAX_GZ_outbound="${MAX_GZ_outbound:-15700000}"

MAX_RAW_phase1_spike="${MAX_RAW_phase1_spike:-29600000}"
MAX_GZ_phase1_spike="${MAX_GZ_phase1_spike:-15400000}"

# oidc_spike (PyreBlog Phase B, 2026-07-03): native-patched build WITH the
# rsa/p256 verify crates — baseline 27,888,228 raw / 14,490,167 gz (gzip -9
# of the patched wasm). Isolated rsa+p256 A/B delta: +123,677 raw /
# +22,214 gz (~0.44%). Threshold ~10% above baseline, per convention.
MAX_RAW_oidc_spike="${MAX_RAW_oidc_spike:-30700000}"
MAX_GZ_oidc_spike="${MAX_GZ_oidc_spike:-15900000}"
